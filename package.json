{
  "name": "@tugudush/jira-mcp",
  "version": "1.0.1",
  "description": "A focused, Jira-only Model Context Protocol server with bitbucket-mcp-grade developer ergonomics. Works today — no OAuth admin gating required.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jira-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "tsx scripts/sync-version.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src scripts tests *.config.ts --ext .ts --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ltfb": "npm run lint && npm run type-check && npm run format && npm run build",
    "start": "node dist/index.js",
    "phase5:smoke": "tsx scripts/phase5-smoke.ts",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "jira",
    "atlassian",
    "jira-cloud",
    "typescript",
    "ai",
    "copilot",
    "claude",
    "cursor"
  ],
  "author": "Jerome Gomez (@tugudush)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tugudush/jira-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/tugudush/jira-mcp/issues"
  },
  "homepage": "https://github.com/tugudush/jira-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toon-format/toon": "^2.3.0",
    "jmespath": "^0.16.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/jmespath": "^0.15.2",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.8.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
