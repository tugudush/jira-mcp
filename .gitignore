# generated files (synced via prebuild; keep generated/ tracked for fresh clones)
# src/generated/version.ts is generated by `npm run prebuild` and SHOULD be
# committed so a fresh `npm ci` works without running build first.
# Therefore it is intentionally NOT in .gitignore.
